# Copy to .env and adjust. If DATABASE_URL is empty, SQLite is used (dev only).

# --- Development defaults ---
SECRET_KEY=dev-insecure-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# Leave empty for SQLite. Example Postgres: postgres://user:pass@localhost:5432/vngrow
DATABASE_URL=
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
TIME_ZONE=Asia/Ho_Chi_Minh

# --- Production (set on Render / host, do NOT commit real values) ---
# SECRET_KEY=<generate a strong 50+ char random string>
# DEBUG=False
# ALLOWED_HOSTS=.onrender.com,api.vngrow.vn
# DATABASE_URL=<managed Postgres connection string>
# CORS_ALLOWED_ORIGINS=https://vngrow.vercel.app,https://app.vngrow.vn
# CSRF_TRUSTED_ORIGINS=https://vngrow.vercel.app,https://app.vngrow.vn
# SECURE_SSL_REDIRECT=True
